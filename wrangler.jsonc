// Cloudflare Workers(静的アセット)設定。SPA リライトはここの not_found_handling で行う
// （_redirects の `/* /index.html 200` は Workers では無限ループ扱いになるため使わない）
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ikura",
  "compatibility_date": "2026-07-05",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": ["nodejs_compat"]
}
